# ===========================================================================
# Quality Autopilot — Environment Configuration
# ===========================================================================
# Copy this file to .env and fill in your values.
#
#   cp example.env .env
#
# SECURITY: Never commit .env to git. Only example.env is tracked.
# ===========================================================================

# ---------------------------------------------------------------------------
# LLM / Inference  (OpenRouter-compatible — Kilo AI Gateway recommended)
# ---------------------------------------------------------------------------
# Get a free key at: https://app.kilo.ai
# Set to your Kilo / OpenRouter API key for inference.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://api.kilo.ai/api/openrouter/v1
KILO_API_KEY=

# ---------------------------------------------------------------------------
# Ollama  (local embeddings — Ollama must be running on host)
# ---------------------------------------------------------------------------
# Install:    https://ollama.ai
# Pull model: ollama pull qwen3-embedding:4b
#
# Use http://localhost:11434 for local dev (outside Docker).
# Use http://host.docker.internal:11434 inside Docker containers.
OLLAMA_HOST=http://host.docker.internal:11434

# ---------------------------------------------------------------------------
# GitHub Integration  (for PR creation by Engineer agent)
# ---------------------------------------------------------------------------
# GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# AUT — Application Under Test
# ---------------------------------------------------------------------------
AUT_BASE_URL=https://gds-demo-app.vercel.app/
# AUT_AUTH_USER=
# AUT_AUTH_PASS=

# ---------------------------------------------------------------------------
# Jira Integration  (for Architect agent — ticket parsing)
# ---------------------------------------------------------------------------
# JIRA_URL=https://your-domain.atlassian.net
# JIRA_USERNAME=your-email@example.com
# JIRA_API_TOKEN=

# ---------------------------------------------------------------------------
# Azure DevOps  (optional alternative to Jira)
# ---------------------------------------------------------------------------
# AZURE_DEVOPS_URL=https://dev.azure.com/your-org
# AZURE_DEVOPS_PAT=

# ---------------------------------------------------------------------------
# Optional: Enhanced Search
# ---------------------------------------------------------------------------
# EXA_API_KEY=
# PARALLEL_API_KEY=

# ---------------------------------------------------------------------------
# Database  (defaults work with Docker Compose out of the box)
# ---------------------------------------------------------------------------
# DB_USER=ai
# DB_PASS=ai
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=ai

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
# RUNTIME_ENV=dev       # dev | prd
# PRINT_ENV_ON_LOAD=False
